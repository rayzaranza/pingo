{
  "name": "pingo-ui",
  "private": false,
  "description": "A UI library made with React that provide design tokens, components and icons.",
  "version": "0.0.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/pingo.js",
      "types": "./dist/pingo.d.ts"
    },
    "./styles.css": "./dist/pingo.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006  --no-open --disable-telemetry",
    "generate-tokens": "pnpm dlx tsx src/tokens/generate-tokens.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.6",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
