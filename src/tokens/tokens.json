{
  "font": {
    "family": {
      "$value": "Outfit, sans-serif",
      "$type": "fontFamily",
      "$description": "Primary sans-serif font. Used across all UI components.",
      "monospace": {
        "$value": "Fira Code, monospace",
        "$type": "fontFamily",
        "$description": "Monospace font. Used for code snippets and technical content."
      }
    },
    "weight": {
      "regular": {
        "$value": 400,
        "$type": "fontWeight",
        "$description": "Regular weight. Used for body text and most UI labels."
      },
      "bold": {
        "$value": 700,
        "$type": "fontWeight",
        "$description": "Bold weight. Used for emphasis and headings."
      }
    },
    "size": {
      "100": {
        "$value": { "value": 0.875, "unit": "rem" },
        "$type": "dimension",
        "$description": "Smallest text size. Used for captions and helper text."
      },
      "200": {
        "$value": { "value": 1, "unit": "rem" },
        "$type": "dimension",
        "$description": "Base text size. Used for body copy and default UI text."
      },
      "300": {
        "$value": { "value": 1.25, "unit": "rem" },
        "$type": "dimension",
        "$description": "Medium text size. Used for subheadings and prominent labels."
      },
      "400": {
        "$value": { "value": 1.5, "unit": "rem" },
        "$type": "dimension",
        "$description": "Large text size. Used for section headings."
      },
      "500": {
        "$value": { "value": 2, "unit": "rem" },
        "$type": "dimension",
        "$description": "Extra large text size. Used for page-level headings."
      }
    }
  },
  "space": {
    "100": {
      "$value": { "value": 0.25, "unit": "rem" },
      "$type": "dimension",
      "$description": "Tightest spacing unit. Used for inline gaps and compact padding."
    },
    "200": {
      "$value": { "value": 0.5, "unit": "rem" },
      "$type": "dimension",
      "$description": "Extra small spacing. Used for icon-to-label gaps."
    },
    "300": {
      "$value": { "value": 0.75, "unit": "rem" },
      "$type": "dimension",
      "$description": "Small spacing. Used for inner padding in compact components."
    },
    "400": {
      "$value": { "value": 1, "unit": "rem" },
      "$type": "dimension",
      "$description": "Base spacing unit. Used for standard component padding."
    },
    "500": {
      "$value": { "value": 1.5, "unit": "rem" },
      "$type": "dimension",
      "$description": "Medium spacing. Used for padding in larger components."
    },
    "600": {
      "$value": { "value": 2, "unit": "rem" },
      "$type": "dimension",
      "$description": "Large spacing. Used for section gaps and generous padding."
    },
    "700": {
      "$value": { "value": 3, "unit": "rem" },
      "$type": "dimension",
      "$description": "Extra large spacing. Used for layout-level gaps."
    },
    "800": {
      "$value": { "value": 4, "unit": "rem" },
      "$type": "dimension",
      "$description": "2XL spacing. Used for page-level margins."
    },
    "900": {
      "$value": { "value": 6, "unit": "rem" },
      "$type": "dimension",
      "$description": "Largest spacing unit. Used for major section separation."
    }
  },
  "size": {
    "small": {
      "$value": { "value": 1.75, "unit": "rem" },
      "$type": "dimension",
      "$description": "Small element height. Used for compact controls."
    },
    "medium": {
      "$value": { "value": 2.25, "unit": "rem" },
      "$type": "dimension",
      "$description": "Default element height. Used for buttons, inputs and row alignment."
    },
    "large": {
      "$value": { "value": 2.75, "unit": "rem" },
      "$type": "dimension",
      "$description": "Large element height. Used for prominent actions and tall controls."
    }
  },
  "radius": {
    "small": {
      "$value": { "value": 4, "unit": "px" },
      "$type": "dimension",
      "$description": "Subtle rounding. Used for tags, badges and compact elements."
    },
    "medium": {
      "$value": { "value": 8, "unit": "px" },
      "$type": "dimension",
      "$description": "Standard rounding. Used for cards, modals and most components."
    },
    "large": {
      "$value": { "value": 16, "unit": "px" },
      "$type": "dimension",
      "$description": "Generous rounding. Used for panels and containers."
    },
    "max": {
      "$value": { "value": 999, "unit": "px" },
      "$type": "dimension",
      "$description": "Pill shape. Used for buttons and fully rounded elements."
    }
  },
